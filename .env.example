# ------------------------------------------------------------
# Core site settings
# ------------------------------------------------------------
# Full site URL used for canonical links / RSS / sitemap.
# Examples:
# - GitHub Pages: https://yourname.github.io
# - Custom domain: https://blog.example.com
SITE_URL=https://yourname.github.io

# Base path for sub-path deployments.
# - Use "/" for root domain deployments.
# - For GitHub Pages project site, use "/<repo-name>".
#   Example: /UEnt26-Blog
BASE_PATH=/

# ------------------------------------------------------------
# Giscus (optional)
# ------------------------------------------------------------
# If any of these values are empty, comments will be disabled.
# Get values from: https://giscus.app
PUBLIC_GISCUS_REPO=owner/repo
PUBLIC_GISCUS_REPO_ID=R_kgDOxxxxxxxxxx
PUBLIC_GISCUS_CATEGORY=General
PUBLIC_GISCUS_CATEGORY_ID=DIC_kwDOxxxxxxxxxx

# ------------------------------------------------------------
# Cloudflare Web Analytics (optional)
# ------------------------------------------------------------
# If empty, analytics script is not injected.
PUBLIC_CF_ANALYTICS_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
