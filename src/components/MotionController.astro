<script is:inline>
  (() => {
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const revealNodes = [...document.querySelectorAll("[data-reveal]")];

    if (revealNodes.length > 0) {
      if (reduceMotion || !("IntersectionObserver" in window)) {
        revealNodes.forEach((node) => node.setAttribute("data-revealed", "true"));
      } else {
        const observer = new IntersectionObserver(
          (entries) => {
            for (const entry of entries) {
              if (!entry.isIntersecting) {
                continue;
              }
              entry.target.setAttribute("data-revealed", "true");
              observer.unobserve(entry.target);
            }
          },
          { threshold: 0.12, rootMargin: "0px 0px -8% 0px" }
        );

        revealNodes.forEach((node) => observer.observe(node));
      }
    }

    const progressRoot = document.querySelector("[data-reading-root]");
    const progressWrap = document.querySelector("[data-reading-progress]");
    const progressBar = document.querySelector("[data-reading-progress-bar]");

    if (!progressWrap || !progressBar) {
      return;
    }

    if (!progressRoot) {
      progressWrap.classList.remove("is-active");
      progressBar.style.transform = "scaleX(0)";
      return;
    }

    progressWrap.classList.add("is-active");

    const updateReadingProgress = () => {
      const rootRect = progressRoot.getBoundingClientRect();
      const viewport = window.innerHeight || document.documentElement.clientHeight;
      const total = Math.max(progressRoot.scrollHeight - viewport * 0.7, 1);
      const current = Math.min(Math.max(-rootRect.top, 0), total);
      const ratio = total === 0 ? 0 : current / total;
      progressBar.style.transform = `scaleX(${Math.max(0, Math.min(1, ratio))})`;
    };

    updateReadingProgress();
    window.addEventListener("scroll", updateReadingProgress, { passive: true });
    window.addEventListener("resize", updateReadingProgress, { passive: true });
  })();
</script>
