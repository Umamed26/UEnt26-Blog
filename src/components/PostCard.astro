---
import type { PostEntry } from "@/utils/posts";
import { getPostTags, normalizeUnlockCode, tagToUrlSegment } from "@/utils/posts";
import { withBasePath } from "@/utils/paths";
import TagPill from "@/components/TagPill.astro";

type Props = {
  post: PostEntry;
  variant?: "default" | "featured-main" | "featured-side";
};

const { post, variant = "default" } = Astro.props as Props;
const tags = getPostTags(post);
const coverSrc = typeof post.data.cover === "string" ? post.data.cover : post.data.cover?.src;
const postHref = withBasePath(`/posts/${post.slug}/`);
const unlockCode = post.data.hidden ? normalizeUnlockCode(post.data.unlockCode) : undefined;
---

<article
  class:list={["surface card", variant]}
  data-unlock-code={unlockCode}
  hidden={post.data.hidden}
>
  {coverSrc ? (
    <img class="cover" src={coverSrc} alt={post.data.title} loading="lazy" decoding="async" />
  ) : (
    <div class="cover placeholder" aria-hidden="true"></div>
  )}

  <div class="content">
    <p class="meta muted">
      <time datetime={post.data.pubDate.toISOString()}>
        {post.data.pubDate.toLocaleDateString("zh-CN")}
      </time>
      {post.data.updatedDate && (
        <span class="updated">
          更新于 {post.data.updatedDate.toLocaleDateString("zh-CN")}
        </span>
      )}
    </p>
    <h2>
      <a href={postHref}>{post.data.title}</a>
    </h2>
    <p class="muted summary">{post.data.description}</p>
    {tags.length > 0 && (
      <div class="tags" aria-label="文章标签">
        {tags.map((tag) => (
          <TagPill tag={tag} href={withBasePath(`/tags/${tagToUrlSegment(tag)}/`)} />
        ))}
      </div>
    )}
    <a class="read-more" href={postHref}>阅读全文</a>
  </div>
</article>

<style>
  .card {
    overflow: hidden;
    display: grid;
    min-height: 100%;
    border-radius: var(--radius-lg);
    background:
      linear-gradient(170deg, rgba(255, 255, 255, 0.98), rgba(249, 243, 232, 0.9));
    transition:
      transform 320ms var(--ease-out),
      box-shadow 320ms var(--ease-out),
      border-color 220ms var(--ease-out);
    position: relative;
  }

  .card::before {
    content: "";
    position: absolute;
    inset: 0 0 auto 0;
    height: 3px;
    background: linear-gradient(90deg, var(--accent), var(--accent-cyan));
    opacity: 0;
    transition: opacity 220ms var(--ease-out);
    pointer-events: none;
    z-index: 1;
  }

  .cover {
    width: 100%;
    height: 184px;
    object-fit: cover;
    border-bottom: 1px solid var(--border);
    transition: transform 380ms var(--ease-out), filter 380ms var(--ease-out);
  }

  .placeholder {
    background:
      linear-gradient(130deg, rgba(196, 82, 55, 0.22), transparent 44%),
      linear-gradient(45deg, rgba(242, 229, 208, 0.9), rgba(234, 224, 208, 0.85)),
      radial-gradient(circle at 70% 25%, rgba(31, 120, 117, 0.18), transparent 56%);
  }

  .content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding: 1rem 1rem 1.2rem;
    gap: 0.66rem;
    align-content: flex-start;
    position: relative;
    z-index: 2;
  }

  .meta {
    margin: 0;
    font-size: 0.78rem;
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
    font-family: "IBM Plex Mono", monospace;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  h2 {
    margin: 0;
    font-size: 1.18rem;
    line-height: 1.3;
    font-family: "Space Grotesk", "IBM Plex Sans", sans-serif;
  }

  h2 a {
    color: var(--text);
  }

  h2 a:hover {
    color: var(--accent);
  }

  .summary {
    margin: 0;
    font-size: 0.95rem;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .read-more {
    margin-top: 0.24rem;
    width: fit-content;
    border: 1px solid rgba(31, 120, 117, 0.34);
    border-radius: 999px;
    padding: 0.25rem 0.62rem;
    color: var(--accent-cyan);
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition:
      transform 220ms var(--ease-out),
      border-color 220ms var(--ease-out),
      background 220ms var(--ease-out);
  }

  .read-more:hover {
    transform: translateY(-1px);
    border-color: rgba(31, 120, 117, 0.52);
    background: rgba(31, 120, 117, 0.1);
    color: var(--accent-cyan);
  }

  .card:hover {
    transform: translateY(-4px);
    border-color: var(--border-strong);
    box-shadow: var(--shadow-strong);
  }

  .card:hover::before {
    opacity: 1;
  }

  .card:hover .cover {
    transform: scale(1.03);
    filter: saturate(105%);
  }

  .featured-main h2 {
    font-size: clamp(1.35rem, 2.2vw, 1.8rem);
    line-height: 1.2;
  }

  .featured-main .cover {
    height: 248px;
  }

  .featured-side h2 {
    font-size: 1.15rem;
  }

  @media (max-width: 899px) {
    .featured-main .cover {
      height: 190px;
    }
  }

  :global(html[data-theme="dark"]) .card {
    background: linear-gradient(170deg, rgba(25, 35, 47, 0.96), rgba(17, 24, 34, 0.9));
  }

  :global(html[data-theme="dark"]) .placeholder {
    background:
      linear-gradient(130deg, rgba(241, 141, 85, 0.24), transparent 44%),
      linear-gradient(45deg, rgba(31, 43, 56, 0.9), rgba(16, 24, 34, 0.86)),
      radial-gradient(circle at 70% 25%, rgba(86, 198, 194, 0.18), transparent 56%);
  }

  :global(html[data-theme="dark"]) .read-more {
    border-color: rgba(86, 198, 194, 0.4);
    color: var(--accent-cyan-soft);
  }

  :global(html[data-theme="dark"]) .read-more:hover {
    border-color: rgba(86, 198, 194, 0.56);
    background: rgba(86, 198, 194, 0.16);
    color: var(--accent-cyan-soft);
  }

  @media (prefers-reduced-motion: reduce) {
    .card,
    .cover,
    .card::before {
      transition: none !important;
    }

    .card:hover {
      transform: none;
    }

    .card:hover .cover {
      transform: none;
    }
  }
</style>
