---
import type { PostEntry } from "@/utils/posts";
import {
  getPostCategoryLabelText,
  getPostProjectSlug,
  getPostSeries,
  getPostTags,
  tagToUrlSegment
} from "@/utils/posts";
import { withBasePath } from "@/utils/paths";
import { getProjectTitleBySlug } from "@/utils/projects";
import TagPill from "@/components/TagPill.astro";

type Props = {
  post: PostEntry;
  variant?: "default" | "featured-main" | "featured-side";
};

const { post, variant = "default" } = Astro.props as Props;
const tags = getPostTags(post);
const coverSrc = typeof post.data.cover === "string" ? post.data.cover : post.data.cover?.src;
const postHref = withBasePath(`/posts/${post.slug}/`);
const series = getPostSeries(post);
const projectSlug = getPostProjectSlug(post);
const projectTitle = projectSlug ? await getProjectTitleBySlug(projectSlug) : undefined;
const readMoreLabel = post.data.hidden ? "解锁阅读" : "阅读全文";
---

<article class:list={["surface card", variant]}>
  {coverSrc ? (
    <img class="cover" src={coverSrc} alt={post.data.title} loading="lazy" decoding="async" />
  ) : (
    <div class="cover placeholder" aria-hidden="true"></div>
  )}

  <div class="content">
    <p class="meta muted">
      <time datetime={post.data.pubDate.toISOString()}>
        {post.data.pubDate.toLocaleDateString("zh-CN")}
      </time>
      {post.data.updatedDate && (
        <span class="updated">
          更新于 {post.data.updatedDate.toLocaleDateString("zh-CN")}
        </span>
      )}
    </p>
    <div class="meta-pills">
      <span class="meta-pill">{getPostCategoryLabelText(post)}</span>
      {post.data.hidden && <span class="meta-pill meta-pill-easter">彩蛋归档</span>}
      {series && <span class="meta-pill meta-pill-soft">系列 · {series}</span>}
      {projectSlug && (
        <a class="meta-pill meta-pill-link" href={withBasePath(`/projects/${projectSlug}/`)}>
          项目 · {projectTitle ?? projectSlug}
        </a>
      )}
    </div>
    <h2>
      <a href={postHref}>{post.data.title}</a>
    </h2>
    <p class="muted summary">{post.data.description}</p>
    {tags.length > 0 && (
      <div class="tags" aria-label="文章标签">
        {tags.map((tag) => (
          <TagPill tag={tag} href={withBasePath(`/tags/${tagToUrlSegment(tag)}/`)} />
        ))}
      </div>
    )}
    <a class="read-more" href={postHref}>{readMoreLabel}</a>
  </div>
</article>

<style>
  .card {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    display: grid;
    min-height: 100%;
    border-radius: 28px;
    border: 1px solid rgba(214, 202, 184, 0.76);
    background:
      radial-gradient(circle at 100% 0%, rgba(31, 120, 117, 0.12), transparent 28%),
      radial-gradient(circle at 0% 0%, rgba(196, 82, 55, 0.12), transparent 24%),
      linear-gradient(160deg, rgba(255, 255, 255, 0.98), rgba(247, 243, 236, 0.94) 58%, rgba(241, 246, 247, 0.92));
    box-shadow:
      0 20px 44px rgba(27, 24, 18, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.8);
    transition:
      transform 280ms var(--ease-out),
      box-shadow 280ms var(--ease-out),
      border-color 220ms var(--ease-out),
      background 220ms var(--ease-out);
  }

  .card::before {
    content: "";
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.46), transparent 16%),
      radial-gradient(circle at 82% 14%, rgba(31, 120, 117, 0.12), transparent 20%);
    opacity: 0.95;
    pointer-events: none;
    z-index: 1;
  }

  .card::after {
    content: "";
    position: absolute;
    top: 1rem;
    left: 1rem;
    right: 1rem;
    height: 1px;
    background: linear-gradient(90deg, rgba(196, 82, 55, 0.48), rgba(31, 120, 117, 0.24), transparent);
    opacity: 0.78;
    pointer-events: none;
    z-index: 2;
  }

  .cover {
    width: 100%;
    height: 210px;
    object-fit: cover;
    border-bottom: 1px solid rgba(214, 202, 184, 0.62);
    transition: transform 420ms var(--ease-out), filter 420ms var(--ease-out);
  }

  .placeholder {
    background:
      radial-gradient(circle at 85% 18%, rgba(31, 120, 117, 0.24), transparent 24%),
      linear-gradient(130deg, rgba(196, 82, 55, 0.22), transparent 42%),
      linear-gradient(45deg, rgba(244, 235, 219, 0.96), rgba(234, 224, 208, 0.9));
  }

  .content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding: 1.28rem 1.28rem 1.38rem;
    gap: 0.9rem;
    align-content: flex-start;
    position: relative;
    z-index: 2;
  }

  .meta {
    margin: 0;
    font-size: 0.74rem;
    display: flex;
    align-items: center;
    gap: 0.55rem;
    flex-wrap: wrap;
    font-family: "IBM Plex Mono", monospace;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-soft);
  }

  h2 {
    margin: 0;
    font-size: 1.22rem;
    line-height: 1.24;
    font-family: "Space Grotesk", "IBM Plex Sans", sans-serif;
    letter-spacing: -0.03em;
  }

  h2 a {
    color: var(--text);
    text-decoration: none;
  }

  h2 a:hover {
    color: var(--accent);
  }

  .summary {
    margin: 0;
    font-size: 0.94rem;
    line-height: 1.68;
    color: var(--text-soft);
  }

  .meta-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .meta-pill {
    border-radius: 999px;
    border: 1px solid rgba(196, 82, 55, 0.24);
    background: rgba(196, 82, 55, 0.07);
    color: var(--accent-strong);
    padding: 0.18rem 0.6rem;
    font-size: 0.72rem;
    letter-spacing: 0.04em;
    line-height: 1.2;
  }

  .meta-pill-soft {
    border-color: rgba(100, 116, 139, 0.22);
    background: rgba(100, 116, 139, 0.08);
    color: var(--text-soft);
  }

  .meta-pill-link {
    border-color: rgba(31, 120, 117, 0.28);
    background: rgba(31, 120, 117, 0.08);
    color: var(--accent-cyan);
  }

  .meta-pill-link:hover {
    border-color: rgba(31, 120, 117, 0.48);
    background: rgba(31, 120, 117, 0.14);
    color: var(--accent-cyan);
  }

  .meta-pill-easter {
    border-color: rgba(100, 116, 139, 0.28);
    background: rgba(100, 116, 139, 0.1);
    color: var(--text-soft);
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
  }

  .read-more {
    margin-top: auto;
    width: fit-content;
    border: 1px solid rgba(31, 120, 117, 0.24);
    border-radius: 999px;
    padding: 0.38rem 0.82rem;
    color: var(--accent-cyan);
    font-size: 0.76rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    background: rgba(255, 255, 255, 0.46);
    transition:
      transform 220ms var(--ease-out),
      border-color 220ms var(--ease-out),
      background 220ms var(--ease-out),
      color 220ms var(--ease-out);
  }

  .read-more::after {
    content: " ↗";
    font-size: 0.8em;
  }

  .read-more:hover {
    transform: translateY(-2px);
    border-color: rgba(31, 120, 117, 0.52);
    background: rgba(31, 120, 117, 0.1);
    color: var(--accent-cyan);
  }

  .card:hover {
    transform: translateY(-6px);
    border-color: rgba(186, 170, 148, 0.9);
    box-shadow:
      0 28px 54px rgba(27, 24, 18, 0.12),
      inset 0 1px 0 rgba(255, 255, 255, 0.86);
  }

  .card:hover .cover {
    transform: scale(1.045);
    filter: saturate(106%) contrast(103%);
  }

  .featured-main h2 {
    font-size: clamp(1.48rem, 2.1vw, 1.92rem);
    line-height: 1.16;
  }

  .featured-main .cover {
    height: 290px;
  }

  .featured-main .content {
    padding: 1.45rem 1.45rem 1.56rem;
    gap: 1rem;
  }

  .featured-side h2 {
    font-size: 1.12rem;
  }

  .featured-side .cover {
    height: 184px;
  }

  @media (max-width: 899px) {
    .featured-main .cover {
      height: 230px;
    }
  }

  :global(html[data-theme="dark"]) .card {
    border-color: rgba(45, 59, 75, 0.95);
    background:
      radial-gradient(circle at 100% 0%, rgba(86, 198, 194, 0.14), transparent 30%),
      radial-gradient(circle at 0% 0%, rgba(241, 141, 85, 0.12), transparent 24%),
      linear-gradient(160deg, rgba(22, 31, 43, 0.98), rgba(16, 23, 33, 0.94) 58%, rgba(12, 19, 28, 0.96));
    box-shadow:
      0 24px 50px rgba(0, 0, 0, 0.28),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }

  :global(html[data-theme="dark"]) .placeholder {
    background:
      radial-gradient(circle at 85% 18%, rgba(86, 198, 194, 0.24), transparent 24%),
      linear-gradient(130deg, rgba(241, 141, 85, 0.24), transparent 42%),
      linear-gradient(45deg, rgba(31, 43, 56, 0.92), rgba(16, 24, 34, 0.88));
  }

  :global(html[data-theme="dark"]) .read-more {
    border-color: rgba(86, 198, 194, 0.4);
    background: rgba(86, 198, 194, 0.08);
    color: var(--accent-cyan-soft);
  }

  :global(html[data-theme="dark"]) .meta-pill {
    border-color: rgba(241, 141, 85, 0.34);
    background: rgba(241, 141, 85, 0.12);
  }

  :global(html[data-theme="dark"]) .meta-pill-soft {
    border-color: rgba(100, 116, 139, 0.42);
    background: rgba(100, 116, 139, 0.18);
    color: #b7c4d8;
  }

  :global(html[data-theme="dark"]) .meta-pill-easter {
    border-color: rgba(100, 116, 139, 0.42);
    background: rgba(100, 116, 139, 0.18);
    color: #d2dae7;
  }

  :global(html[data-theme="dark"]) .meta-pill-link {
    border-color: rgba(86, 198, 194, 0.34);
    background: rgba(86, 198, 194, 0.12);
    color: var(--accent-cyan-soft);
  }

  :global(html[data-theme="dark"]) .summary,
  :global(html[data-theme="dark"]) .meta {
    color: #b7c4d8;
  }

  :global(html[data-theme="dark"]) .read-more:hover {
    border-color: rgba(86, 198, 194, 0.56);
    background: rgba(86, 198, 194, 0.16);
    color: var(--accent-cyan-soft);
  }

  @media (prefers-reduced-motion: reduce) {
    .card,
    .cover,
    .card::before {
      transition: none !important;
    }

    .card:hover {
      transform: none;
    }

    .card:hover .cover {
      transform: none;
    }
  }
</style>
