---
import { getProjectStatusDescription, getProjectStatusLabel } from "@/config/taxonomy";
import { withBasePath } from "@/utils/paths";
import type { ProjectEntry } from "@/utils/projects";

type Props = {
  project: ProjectEntry;
  variant?: "default" | "compact";
};

const { project, variant = "default" } = Astro.props as Props;
const detailHref = withBasePath(`/projects/${project.slug}/`);
const projectLinks = project.data.links.slice(0, variant === "compact" ? 1 : 2);
const statusClass = `status-${project.data.status}`;
const updatedLabel = project.data.updatedDate?.toLocaleDateString("zh-CN");
---

<article class:list={["surface project-card", variant]}>
  <div class="card-head">
    <div class="title-wrap">
      <p class:list={["status-pill", statusClass]}>{getProjectStatusLabel(project.data.status)}</p>
      <h3>
        <a href={detailHref}>{project.data.title}</a>
      </h3>
    </div>
    {updatedLabel && <p class="meta">更新于 {updatedLabel}</p>}
  </div>

  <p class="muted summary">{project.data.summary}</p>
  <p class="muted status-desc">{getProjectStatusDescription(project.data.status)}</p>

  {project.data.stack.length > 0 && (
    <div class="chip-row" aria-label="项目技术栈">
      {project.data.stack.map((item) => (
        <span class="chip">{item}</span>
      ))}
    </div>
  )}

  {project.data.highlights.length > 0 && (
    <ul class="highlight-list">
      {project.data.highlights.slice(0, variant === "compact" ? 2 : 3).map((item) => (
        <li>{item}</li>
      ))}
    </ul>
  )}

  <div class="link-row">
    <a class="primary-link" href={detailHref}>查看详情</a>
    {projectLinks.map((item) => (
      <a href={withBasePath(item.href)}>{item.label}</a>
    ))}
  </div>
</article>

<style>
  .project-card {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    display: grid;
    gap: 1rem;
    padding: 1.25rem;
    border-radius: 28px;
    min-height: 100%;
    border: 1px solid rgba(214, 202, 184, 0.76);
    background:
      radial-gradient(circle at 100% 0%, rgba(31, 120, 117, 0.12), transparent 28%),
      radial-gradient(circle at 0% 0%, rgba(196, 82, 55, 0.1), transparent 22%),
      linear-gradient(160deg, rgba(255, 255, 255, 0.98), rgba(248, 243, 235, 0.95) 58%, rgba(242, 246, 247, 0.92));
    box-shadow:
      0 20px 44px rgba(27, 24, 18, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.82);
    transition:
      transform 280ms var(--ease-out),
      box-shadow 280ms var(--ease-out),
      border-color 220ms var(--ease-out);
  }

  .project-card::before {
    content: "";
    position: absolute;
    top: 1rem;
    left: 1rem;
    right: 1rem;
    height: 1px;
    background: linear-gradient(90deg, rgba(31, 120, 117, 0.44), rgba(196, 82, 55, 0.28), transparent);
    opacity: 0.8;
    pointer-events: none;
    z-index: 1;
  }

  .card-head {
    display: grid;
    gap: 0.72rem;
    position: relative;
    z-index: 2;
  }

  .title-wrap {
    display: grid;
    gap: 0.6rem;
  }

  .status-pill {
    margin: 0;
    width: fit-content;
    border-radius: 999px;
    padding: 0.22rem 0.66rem;
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-family: "IBM Plex Mono", monospace;
    border: 1px solid transparent;
  }

  .status-active {
    border-color: rgba(196, 82, 55, 0.32);
    background: rgba(196, 82, 55, 0.1);
    color: var(--accent-strong);
  }

  .status-maintain {
    border-color: rgba(31, 120, 117, 0.3);
    background: rgba(31, 120, 117, 0.08);
    color: var(--accent-cyan);
  }

  .status-plan,
  .status-inactive {
    border-color: rgba(100, 116, 139, 0.34);
    background: rgba(100, 116, 139, 0.1);
    color: var(--text-soft);
  }

  h3 {
    margin: 0;
    font-size: 1.22rem;
    line-height: 1.2;
    font-family: "Space Grotesk", "IBM Plex Sans", sans-serif;
    letter-spacing: -0.03em;
  }

  h3 a {
    color: var(--text);
    text-decoration: none;
  }

  h3 a:hover {
    color: var(--accent);
  }

  .meta,
  .summary,
  .status-desc {
    margin: 0;
  }

  .summary,
  .status-desc {
    line-height: 1.68;
  }

  .meta {
    font-size: 0.74rem;
    color: var(--text-soft);
    font-family: "IBM Plex Mono", monospace;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .status-desc {
    font-size: 0.9rem;
  }

  .chip-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.52rem;
  }

  .chip {
    border-radius: 999px;
    border: 1px solid rgba(31, 120, 117, 0.24);
    background: rgba(31, 120, 117, 0.06);
    color: var(--accent-cyan);
    padding: 0.22rem 0.58rem;
    font-size: 0.76rem;
  }

  .highlight-list {
    margin: 0;
    padding-left: 1.1rem;
    display: grid;
    gap: 0.45rem;
  }

  .highlight-list li {
    color: var(--text);
    line-height: 1.5;
  }

  .link-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    margin-top: auto;
  }

  .link-row a {
    border-radius: 999px;
    border: 1px solid rgba(31, 120, 117, 0.28);
    padding: 0.34rem 0.78rem;
    color: var(--accent-cyan);
    font-size: 0.76rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: rgba(255, 255, 255, 0.44);
    transition:
      transform 220ms var(--ease-out),
      border-color 220ms var(--ease-out),
      background 220ms var(--ease-out);
  }

  .link-row a:hover {
    transform: translateY(-2px);
    border-color: rgba(31, 120, 117, 0.48);
    background: rgba(31, 120, 117, 0.1);
    color: var(--accent-cyan);
  }

  .primary-link {
    border-color: rgba(196, 82, 55, 0.34) !important;
    background: rgba(196, 82, 55, 0.1);
    color: var(--accent-strong) !important;
  }

  .primary-link:hover {
    border-color: rgba(196, 82, 55, 0.5) !important;
    background: rgba(196, 82, 55, 0.16) !important;
  }

  .compact {
    gap: 0.82rem;
  }

  .compact h3 {
    font-size: 1.12rem;
  }

  .compact .status-desc {
    font-size: 0.84rem;
  }

  .project-card:hover {
    transform: translateY(-6px);
    border-color: rgba(186, 170, 148, 0.9);
    box-shadow:
      0 28px 54px rgba(27, 24, 18, 0.12),
      inset 0 1px 0 rgba(255, 255, 255, 0.86);
  }

  :global(html[data-theme="dark"]) .status-active {
    border-color: rgba(241, 141, 85, 0.4);
    background: rgba(241, 141, 85, 0.14);
  }

  :global(html[data-theme="dark"]) .project-card {
    border-color: rgba(45, 59, 75, 0.95);
    background:
      radial-gradient(circle at 100% 0%, rgba(86, 198, 194, 0.14), transparent 30%),
      radial-gradient(circle at 0% 0%, rgba(241, 141, 85, 0.1), transparent 24%),
      linear-gradient(160deg, rgba(22, 31, 43, 0.98), rgba(16, 23, 33, 0.94) 58%, rgba(12, 19, 28, 0.96));
    box-shadow:
      0 24px 50px rgba(0, 0, 0, 0.28),
      inset 0 1px 0 rgba(255, 255, 255, 0.05);
  }

  :global(html[data-theme="dark"]) .status-maintain {
    border-color: rgba(86, 198, 194, 0.34);
    background: rgba(86, 198, 194, 0.12);
    color: var(--accent-cyan-soft);
  }

  :global(html[data-theme="dark"]) .status-plan,
  :global(html[data-theme="dark"]) .status-inactive {
    border-color: rgba(100, 116, 139, 0.5);
    background: rgba(100, 116, 139, 0.2);
    color: #b7c4d8;
  }

  :global(html[data-theme="dark"]) .chip,
  :global(html[data-theme="dark"]) .link-row a {
    border-color: rgba(86, 198, 194, 0.34);
    background: rgba(86, 198, 194, 0.12);
    color: var(--accent-cyan-soft);
  }

  :global(html[data-theme="dark"]) .summary,
  :global(html[data-theme="dark"]) .status-desc,
  :global(html[data-theme="dark"]) .meta {
    color: #b7c4d8;
  }

  :global(html[data-theme="dark"]) .primary-link {
    border-color: rgba(241, 141, 85, 0.45) !important;
    background: rgba(241, 141, 85, 0.16) !important;
    color: var(--accent-strong) !important;
  }
</style>
