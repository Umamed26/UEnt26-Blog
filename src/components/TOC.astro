---
type Heading = {
  depth: number;
  slug: string;
  text: string;
};

type Props = {
  headings: Heading[];
};

const { headings } = Astro.props as Props;

if (!headings.length) {
  return null;
}
---

<aside class="surface toc">
  <p class="toc-title">目录</p>
  <ul>
    {headings.map((item) => (
      <li class:list={["depth", `d-${item.depth}`]}>
        <a href={`#${item.slug}`}>{item.text}</a>
      </li>
    ))}
  </ul>
</aside>

<style>
  .toc {
    padding: 1rem;
    position: sticky;
    top: 96px;
    border-radius: 18px;
    border: 1px solid rgba(218, 205, 184, 0.9);
    background:
      linear-gradient(160deg, rgba(255, 255, 255, 0.94), rgba(246, 238, 223, 0.9));
    backdrop-filter: blur(12px);
  }

  .toc-title {
    margin: 0 0 0.8rem;
    font-size: 0.78rem;
    color: var(--accent-cyan);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  ul {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.55rem;
  }

  li {
    font-size: 0.92rem;
    line-height: 1.35;
  }

  .d-3 {
    padding-left: 0.8rem;
  }

  .d-4 {
    padding-left: 1.4rem;
  }

  a {
    color: var(--text-soft);
    transition: color 220ms var(--ease-out), transform 220ms var(--ease-out);
    display: inline-block;
  }

  a:hover {
    color: var(--accent-cyan);
    transform: translateX(2px);
  }

  :global(html[data-theme="dark"]) .toc {
    border-color: rgba(45, 59, 75, 0.95);
    background: linear-gradient(160deg, rgba(26, 36, 48, 0.95), rgba(17, 24, 34, 0.92));
  }

  :global(html[data-theme="dark"]) .toc-title {
    color: var(--accent-cyan-soft);
  }

  :global(html[data-theme="dark"]) a:hover {
    color: var(--accent-cyan-soft);
  }
</style>
