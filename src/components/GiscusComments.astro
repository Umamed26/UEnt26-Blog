---
const repo = import.meta.env.PUBLIC_GISCUS_REPO;
const repoId = import.meta.env.PUBLIC_GISCUS_REPO_ID;
const category = import.meta.env.PUBLIC_GISCUS_CATEGORY;
const categoryId = import.meta.env.PUBLIC_GISCUS_CATEGORY_ID;

const enabled = Boolean(repo && repoId && category && categoryId);

if (!enabled) {
  return null;
}
---

<section class="surface comments" aria-label="评论区">
  <h2>评论</h2>
  <div
    id="giscus-root"
    data-repo={repo}
    data-repo-id={repoId}
    data-category={category}
    data-category-id={categoryId}
    data-mapping="pathname"
    data-strict="0"
    data-reactions-enabled="1"
    data-emit-metadata="0"
    data-input-position="top"
    data-lang="zh-CN"
    data-loading="lazy"
  ></div>
  <p id="giscus-fallback" class="fallback" hidden>评论暂时未加载，请稍后重试。</p>
  <script is:inline>
    (() => {
      const root = document.getElementById("giscus-root");
      const fallback = document.getElementById("giscus-fallback");
      const getTheme = () =>
        document.documentElement.getAttribute("data-theme") === "dark" ? "dark_dimmed" : "light";

      if (!(root instanceof HTMLElement)) {
        return;
      }

      const applyTheme = () => {
        const frame = document.querySelector("iframe.giscus-frame");
        if (!(frame instanceof HTMLIFrameElement) || !frame.contentWindow) {
          return;
        }

        frame.contentWindow.postMessage(
          {
            giscus: {
              setConfig: {
                theme: getTheme()
              }
            }
          },
          "https://giscus.app"
        );
      };

      const script = document.createElement("script");
      script.src = "https://giscus.app/client.js";
      script.async = true;
      script.crossOrigin = "anonymous";
      script.setAttribute("data-theme", getTheme());

      for (const attribute of root.attributes) {
        if (attribute.name.startsWith("data-") && attribute.name !== "data-theme") {
          script.setAttribute(attribute.name, attribute.value);
        }
      }

      script.onerror = () => {
        if (fallback instanceof HTMLElement) {
          fallback.hidden = false;
        }
      };

      script.onload = () => {
        applyTheme();
      };

      window.addEventListener("theme:changed", applyTheme);
      root.appendChild(script);
    })();
  </script>
</section>

<style>
  .comments {
    margin-top: 2rem;
    padding: 1rem;
  }

  h2 {
    margin-top: 0;
    margin-bottom: 0.9rem;
    font-size: 1.1rem;
  }

  .fallback {
    color: var(--text-soft);
    margin: 0.4rem 0 0;
    font-size: 0.9rem;
  }
</style>
