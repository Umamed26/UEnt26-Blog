---
import { render } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import CodeBlockWrapper from "@/components/CodeBlockWrapper.astro";
import GiscusComments from "@/components/GiscusComments.astro";
import TagPill from "@/components/TagPill.astro";
import TOC from "@/components/TOC.astro";
import { withBasePath } from "@/utils/paths";
import {
  getAllPublishedPosts,
  getPostTags,
  getRelatedPosts,
  tagToUrlSegment,
  type PostEntry
} from "@/utils/posts";

type Props = {
  post: PostEntry;
};

export async function getStaticPaths() {
  const posts = await getAllPublishedPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post }
  }));
}

const { post } = Astro.props as Props;
const { Content, headings } = await render(post);
const toc = post.data.toc ? headings.filter((item) => item.depth >= 2 && item.depth <= 3) : [];
const tags = getPostTags(post);
const allPosts = await getAllPublishedPosts();
const relatedPosts = getRelatedPosts(allPosts, post, 4);
const canonicalPath = `/posts/${post.slug}/`;
const coverSrc = typeof post.data.cover === "string" ? post.data.cover : post.data.cover?.src;
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  canonicalPath={canonicalPath}
  image={coverSrc}
>
  <article class="stack post-shell" data-reading-root>
    <header class="surface post-header" data-reveal>
      <p class="section-kicker">Article</p>
      <h1 class="page-title">{post.data.title}</h1>
      <p class="muted summary">{post.data.description}</p>
    </header>

    <section class="surface meta-band" data-reveal style="--reveal-delay: 80ms;">
      <div class="meta-row">
        <span class="meta-label">发布</span>
        <time datetime={post.data.pubDate.toISOString()}>
          {post.data.pubDate.toLocaleDateString("zh-CN")}
        </time>
      </div>
      {post.data.updatedDate && (
        <div class="meta-row">
          <span class="meta-label">更新</span>
          <time datetime={post.data.updatedDate.toISOString()}>
            {post.data.updatedDate.toLocaleDateString("zh-CN")}
          </time>
        </div>
      )}
      {typeof post.data.pinned === "number" && (
        <div class="meta-row">
          <span class="meta-label">置顶权重</span>
          <span>#{post.data.pinned}</span>
        </div>
      )}
      {tags.length > 0 && (
        <div class="meta-tags">
          {tags.map((tag) => (
            <TagPill tag={tag} href={`/tags/${tagToUrlSegment(tag)}/`} />
          ))}
        </div>
      )}
    </section>

    <div class="article-layout" data-reveal style="--reveal-delay: 120ms;">
      <CodeBlockWrapper>
        <Content />
      </CodeBlockWrapper>
      <div class="toc-wrap">
        <TOC headings={toc} />
      </div>
    </div>

    {relatedPosts.length > 0 && (
      <section class="stack related-section" data-reveal style="--reveal-delay: 160ms;">
        <div>
          <p class="section-kicker">Keep Reading</p>
          <h2 class="section-title">相关文章</h2>
        </div>
        <div class="related-grid">
          {relatedPosts.map(({ post: relatedPost, sharedTags }) => (
            <article class="surface related-card">
              <p class="related-meta">
                <time datetime={relatedPost.data.pubDate.toISOString()}>
                  {relatedPost.data.pubDate.toLocaleDateString("zh-CN")}
                </time>
                {relatedPost.data.updatedDate && (
                  <span>更新于 {relatedPost.data.updatedDate.toLocaleDateString("zh-CN")}</span>
                )}
              </p>
              <h3 class="related-title">
                <a href={withBasePath(`/posts/${relatedPost.slug}/`)}>{relatedPost.data.title}</a>
              </h3>
              <p class="muted related-desc">{relatedPost.data.description}</p>
              {sharedTags.length > 0 && (
                <div class="related-tags" aria-label="共同标签">
                  {sharedTags.map((tag) => (
                    <TagPill tag={tag} href={withBasePath(`/tags/${tagToUrlSegment(tag)}/`)} />
                  ))}
                </div>
              )}
            </article>
          ))}
        </div>
      </section>
    )}

    <div data-reveal style="--reveal-delay: 200ms;">
      <GiscusComments />
    </div>
  </article>
</BaseLayout>

<style>
  .post-shell {
    gap: 1.35rem;
  }

  .post-header {
    padding: clamp(1.1rem, 2.2vw, 1.55rem);
    border-radius: var(--radius-lg);
  }

  .summary {
    margin: 0;
    max-width: 64ch;
  }

  .meta-band {
    display: grid;
    gap: 0.7rem;
    padding: 1rem;
    border-radius: 16px;
    border-color: rgba(218, 205, 184, 0.9);
  }

  .meta-row {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    font-size: 0.86rem;
    color: var(--text-soft);
  }

  .meta-label {
    border: 1px solid rgba(31, 120, 117, 0.3);
    border-radius: 999px;
    padding: 0.1rem 0.48rem;
    color: var(--accent-cyan);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .meta-tags {
    display: flex;
    gap: 0.45rem;
    flex-wrap: wrap;
    margin-top: 0.1rem;
  }

  .article-layout {
    display: grid;
    gap: 1.2rem;
    align-items: start;
  }

  .related-section {
    gap: 0.8rem;
  }

  .related-grid {
    display: grid;
    gap: 0.8rem;
  }

  .related-card {
    border-radius: 16px;
    padding: 0.95rem;
    border-color: rgba(218, 205, 184, 0.9);
    display: grid;
    gap: 0.56rem;
  }

  .related-meta {
    margin: 0;
    font-size: 0.76rem;
    color: var(--text-soft);
    display: flex;
    gap: 0.55rem;
    flex-wrap: wrap;
    font-family: "IBM Plex Mono", monospace;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }

  .related-title {
    margin: 0;
    font-size: 1.05rem;
    line-height: 1.35;
    font-family: "Space Grotesk", "IBM Plex Sans", sans-serif;
  }

  .related-title a {
    color: var(--text);
  }

  .related-title a:hover {
    color: var(--accent);
  }

  .related-desc {
    margin: 0;
    font-size: 0.92rem;
    line-height: 1.48;
  }

  .related-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.42rem;
  }

  @media (min-width: 1120px) {
    .article-layout {
      grid-template-columns: minmax(0, 1fr) 270px;
    }
  }

  @media (min-width: 860px) {
    .related-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 1119px) {
    .toc-wrap {
      display: none;
    }
  }

  :global(html[data-theme="dark"]) .meta-band {
    border-color: rgba(45, 59, 75, 0.95);
  }

  :global(html[data-theme="dark"]) .related-card {
    border-color: rgba(45, 59, 75, 0.95);
  }

  :global(html[data-theme="dark"]) .meta-label {
    border-color: rgba(86, 198, 194, 0.4);
    color: var(--accent-cyan-soft);
  }
</style>
