---
import ProjectCard from "@/components/ProjectCard.astro";
import { projectStatusValues, getProjectStatusLabel } from "@/config/taxonomy";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getAllPublishedPosts, getPostsByProject } from "@/utils/posts";
import { getAllProjects } from "@/utils/projects";

const projects = await getAllProjects();
const posts = await getAllPublishedPosts();
const featuredProjects = projects.filter((project) => project.data.featured).slice(0, 3);

const statusStats = projectStatusValues.map((status) => ({
  status,
  label: getProjectStatusLabel(status),
  value: projects.filter((project) => project.data.status === status).length
}));

const projectSummaries = projects.map((project) => ({
  slug: project.slug,
  title: project.data.title,
  postCount: getPostsByProject(posts, project.slug).length
}));
---

<BaseLayout title="Projects">
  <section class="stack projects-page" data-reveal>
    <header class="surface projects-hero">
      <div class="hero-copy">
        <p class="section-kicker">Projects</p>
        <h1 class="page-title">项目</h1>
        <p class="muted">
          这里收录我正在做、维护中、计划中以及已经停更但仍值得保留的项目。它们和文章一起，构成这个站的第二条主线。
        </p>
      </div>

      <div class="stats-grid" aria-label="项目状态概览">
        {statusStats.map((item) => (
          <article class="surface stat-card">
            <p class="stat-value">{String(item.value).padStart(2, "0")}</p>
            <p class="stat-label">{item.label}</p>
          </article>
        ))}
      </div>
    </header>

    {featuredProjects.length > 0 && (
      <section class="stack" data-reveal style="--reveal-delay: 70ms;">
        <div class="section-head">
          <div>
            <p class="section-kicker">Current Focus</p>
            <h2 class="section-title">当前重点</h2>
          </div>
          <p class="muted section-note">优先展示现在最值得打开继续看的项目。</p>
        </div>
        <div class="project-grid featured-grid">
          {featuredProjects.map((project) => (
            <ProjectCard project={project} />
          ))}
        </div>
      </section>
    )}

    <section class="project-layout" data-reveal style="--reveal-delay: 110ms;">
      <div class="stack all-projects">
        <div class="section-head">
          <div>
            <p class="section-kicker">Full Index</p>
            <h2 class="section-title">全部项目</h2>
          </div>
          <p class="muted section-note">项目详情页会继续沉淀背景、阶段目标和相关文章。</p>
        </div>

        <div class="project-grid">
          {projects.map((project) => (
            <ProjectCard project={project} />
          ))}
        </div>
      </div>

      <aside class="stack sidebar">
        <section class="surface sidebar-card">
          <p class="section-kicker">Writing Bridge</p>
          <h2 class="section-title">项目和文章的连接</h2>
          <ul class="meta-list">
            {projectSummaries.map((item) => (
              <li>
                <span>{item.title}</span>
                <strong>{item.postCount} 篇关联文章</strong>
              </li>
            ))}
          </ul>
        </section>

        <section class="surface sidebar-card">
          <p class="section-kicker">How I Work</p>
          <h2 class="section-title">项目页会记录什么</h2>
          <ul class="bullet-list">
            <li>这个项目为什么值得做。</li>
            <li>它现在处于什么阶段。</li>
            <li>后续相关开发日志或站内文章。</li>
          </ul>
        </section>
      </aside>
    </section>
  </section>
</BaseLayout>

<style>
  .projects-page {
    gap: 1.2rem;
  }

  .projects-hero {
    padding: clamp(1.1rem, 2.8vw, 1.5rem);
    border-radius: var(--radius-lg);
    display: grid;
    gap: 1rem;
  }

  .hero-copy {
    display: grid;
    gap: 0.7rem;
  }

  .hero-copy p {
    margin: 0;
    max-width: 66ch;
  }

  .stats-grid {
    display: grid;
    gap: 0.9rem;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
  }

  .stat-card {
    border-radius: 16px;
    padding: 1.05rem;
    display: grid;
    gap: 0.3rem;
  }

  .stat-value,
  .stat-label {
    margin: 0;
  }

  .stat-value {
    font-size: 1.7rem;
    font-family: "Space Grotesk", "IBM Plex Sans", sans-serif;
  }

  .stat-label {
    color: var(--text-soft);
    font-size: 0.84rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-family: "IBM Plex Mono", monospace;
  }

  .section-head {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .section-note {
    margin: 0;
    max-width: 42ch;
  }

  .project-layout {
    display: grid;
    gap: 1rem;
    align-items: start;
  }

  .all-projects,
  .sidebar {
    gap: 1rem;
  }

  .project-grid {
    display: grid;
    gap: 1.05rem;
  }

  .sidebar-card {
    padding: 1.1rem;
    border-radius: 18px;
    display: grid;
    gap: 0.85rem;
  }

  .meta-list,
  .bullet-list {
    margin: 0;
    padding-left: 1.1rem;
    display: grid;
    gap: 0.55rem;
  }

  .meta-list li,
  .bullet-list li {
    color: var(--text);
    line-height: 1.55;
  }

  .meta-list strong {
    display: block;
    margin-top: 0.1rem;
    color: var(--accent-cyan);
    font-size: 0.84rem;
  }

  @media (min-width: 980px) {
    .featured-grid,
    .project-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .project-layout {
      grid-template-columns: minmax(0, 1.7fr) minmax(280px, 0.9fr);
    }
  }

  @media (min-width: 1240px) {
    .featured-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  :global(html[data-theme="dark"]) .stat-card,
  :global(html[data-theme="dark"]) .sidebar-card {
    border-color: rgba(45, 59, 75, 0.95);
  }
</style>
