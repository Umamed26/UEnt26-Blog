---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { withBasePath } from "@/utils/paths";

type ProjectLink = {
  label: string;
  href: string;
};

type ProjectItem = {
  name: string;
  status: "进行中" | "维护中" | "规划中";
  tone: "active" | "maintain" | "plan";
  summary: string;
  stack: string[];
  highlights: string[];
  links: ProjectLink[];
};

const projects: ProjectItem[] = [
  {
    name: "Pixel Workshop",
    status: "维护中",
    tone: "maintain",
    summary: "图片像素化网站，可将图片转换为像素风格。",
    stack: ["React ", "TypeScript", "Vite"],
    highlights: ["支持多种像素化选项", "实时预览效果"],
    links: [
      { label: "访问网站", href: "https://umamed26.github.io/Pixel_Converter/" }
    ]
  },
  {
    name: "UEnt26 Blog",
    status: "进行中",
    tone: "active",
    summary: "个人网站。",
    stack: ["Astro", "TypeScript", "Markdown", "Giscus"],
    highlights: ["想到什么做什么"],
    links: [
      { label: "查看首页", href: withBasePath("/") },
      { label: "归档实验室", href: withBasePath("/archive/") }
    ]
  },
  {
    name: "Path to Dishonor",
    status: "进行中",
    tone: "active",
    summary: "使用python做的classic rougelike游戏。",
    stack: ["Python"],
    highlights: ["更新v0.6", "上线Beta版"],
    links: [{ label: "itch.io页面（假的）", href: withBasePath("/console/") }]
  },
  {
    name: "Bash the Spire",
    status: "规划中",
    tone: "plan",
    summary: "杀戮尖塔，但是终端版。",
    stack: ["???"],
    highlights: ["不知道哇"],
    links: [
      { label: "占位符", href: withBasePath("/now/") }
    ]
  }
];
---

<BaseLayout title="Projects">
  <section class="stack projects-page" data-reveal>
    <header class="surface projects-hero">
      <p class="section-kicker">Projects</p>
      <h1 class="page-title">项目</h1>
      <p class="muted">
        这里记录我正在做、已经上线以及下一步准备推进的项目。
      </p>
    </header>

    <div class="projects-grid" data-reveal style="--reveal-delay: 80ms;">
      {projects.map((project) => (
        <article class="surface project-card">
          <div class="project-head">
            <h2>{project.name}</h2>
            <span class={`status status-${project.tone}`}>{project.status}</span>
          </div>

          <p class="muted project-summary">{project.summary}</p>

          <div class="stack-group">
            {project.stack.map((item) => (
              <span class="chip">{item}</span>
            ))}
          </div>

          <ul class="highlight-list">
            {project.highlights.map((item) => (
              <li>{item}</li>
            ))}
          </ul>

          <div class="link-row">
            {project.links.map((link) => (
              <a href={link.href}>{link.label}</a>
            ))}
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .projects-page {
    gap: 1rem;
  }

  .projects-hero {
    padding: 1.2rem;
    border-radius: var(--radius-lg);
    display: grid;
    gap: 0.68rem;
  }

  .projects-hero p {
    margin: 0;
  }

  .projects-grid {
    display: grid;
    gap: 0.85rem;
  }

  .project-card {
    border-radius: 18px;
    border-color: rgba(218, 205, 184, 0.9);
    padding: 1rem;
    display: grid;
    grid-template-rows: auto auto auto auto 1fr auto;
    min-height: 246px;
    gap: 0.72rem;
  }

  .project-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 0.8rem;
    flex-wrap: wrap;
  }

  .project-head h2 {
    margin: 0;
    font-size: 1.18rem;
    line-height: 1.3;
    font-family: "Space Grotesk", "IBM Plex Sans", sans-serif;
  }

  .status {
    display: inline-flex;
    align-items: center;
    align-self: flex-start;
    min-height: 1.75rem;
    line-height: 1;
    border-radius: 999px;
    padding: 0.16rem 0.62rem;
    font-size: 0.74rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-family: "IBM Plex Mono", monospace;
    border: 1px solid transparent;
  }

  .status-active {
    color: var(--accent-strong);
    border-color: rgba(159, 57, 34, 0.42);
    background: rgba(196, 82, 55, 0.12);
  }

  .status-maintain {
    color: var(--accent-cyan);
    border-color: rgba(31, 120, 117, 0.42);
    background: rgba(31, 120, 117, 0.12);
  }

  .status-plan {
    color: var(--text-soft);
    border-color: rgba(106, 97, 86, 0.35);
    background: rgba(106, 97, 86, 0.09);
  }

  .project-summary {
    margin: 0;
    line-height: 1.55;
  }

  .stack-group {
    display: flex;
    gap: 0.42rem;
    flex-wrap: wrap;
  }

  .chip {
    border-radius: 999px;
    border: 1px solid rgba(31, 120, 117, 0.3);
    background: rgba(31, 120, 117, 0.08);
    color: var(--accent-cyan);
    font-size: 0.75rem;
    padding: 0.12rem 0.52rem;
  }

  .highlight-list {
    margin: 0;
    padding-left: 1.05rem;
    display: grid;
    gap: 0.42rem;
  }

  .link-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin-top: auto;
  }

  .link-row a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 2rem;
    line-height: 1;
    border-radius: 999px;
    border: 1px solid rgba(31, 120, 117, 0.34);
    background: rgba(31, 120, 117, 0.08);
    color: var(--accent-cyan);
    font-size: 0.8rem;
    font-weight: 600;
    padding: 0.2rem 0.65rem;
    transition:
      border-color 220ms var(--ease-out),
      background 220ms var(--ease-out),
      transform 220ms var(--ease-out);
  }

  .link-row a:hover {
    transform: translateY(-1px);
    border-color: rgba(31, 120, 117, 0.52);
    background: rgba(31, 120, 117, 0.16);
    color: var(--accent-cyan);
  }

  @media (min-width: 900px) {
    .projects-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 899px) {
    .project-card {
      min-height: auto;
    }
  }

  :global(html[data-theme="dark"]) .project-card {
    border-color: rgba(45, 59, 75, 0.95);
  }

  :global(html[data-theme="dark"]) .status-active {
    border-color: rgba(241, 141, 85, 0.52);
    background: rgba(241, 141, 85, 0.16);
    color: var(--accent-strong);
  }

  :global(html[data-theme="dark"]) .status-maintain {
    border-color: rgba(86, 198, 194, 0.48);
    background: rgba(86, 198, 194, 0.16);
    color: var(--accent-cyan-soft);
  }

  :global(html[data-theme="dark"]) .status-plan {
    border-color: rgba(100, 116, 139, 0.5);
    background: rgba(100, 116, 139, 0.2);
    color: #b7c4d8;
  }

  :global(html[data-theme="dark"]) .chip,
  :global(html[data-theme="dark"]) .link-row a {
    border-color: rgba(86, 198, 194, 0.34);
    background: rgba(86, 198, 194, 0.12);
    color: var(--accent-cyan-soft);
  }

  :global(html[data-theme="dark"]) .link-row a:hover {
    border-color: rgba(86, 198, 194, 0.52);
    background: rgba(86, 198, 194, 0.2);
    color: var(--accent-cyan-soft);
  }
</style>
