---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getPostCategoryLabel } from "@/config/taxonomy";
import { getAllPublishedPosts, getPostTags, tagToUrlSegment } from "@/utils/posts";
import { getAllProjects } from "@/utils/projects";
import { withBasePath } from "@/utils/paths";

const pad = (value: number) => String(value).padStart(2, "0");
const getDateKey = (date: Date) => date.toISOString().slice(0, 10);
const tagBaseHref = withBasePath("/tags/");
const projectBaseHref = withBasePath("/projects/");

const posts = await getAllPublishedPosts({ includeHidden: true });
const projects = await getAllProjects();
const projectTitleMap = new Map(projects.map((project) => [project.slug, project.data.title]));

const archiveItems = posts.map((post) => {
  const published = post.data.pubDate;
  const updated = post.data.updatedDate;
  const tags = getPostTags(post);
  const year = String(published.getFullYear());
  const month = pad(published.getMonth() + 1);
  const day = pad(published.getDate());

  return {
    slug: post.slug,
    href: withBasePath(`/posts/${post.slug}/`),
    title: post.data.title,
    description: post.data.description,
    hidden: post.data.hidden === true,
    tags,
    category: post.data.category,
    categoryLabel: getPostCategoryLabel(post.data.category),
    series: post.data.series ?? null,
    project: post.data.project ?? null,
    projectLabel: post.data.project ? (projectTitleMap.get(post.data.project) ?? post.data.project) : null,
    year,
    month,
    day,
    monthKey: `${year}-${month}`,
    dayKey: `${year}-${month}-${day}`,
    dateISO: published.toISOString(),
    dateKey: getDateKey(published),
    dateLabel: published.toLocaleDateString("zh-CN"),
    updatedDateISO: updated ? updated.toISOString() : null,
    updatedDateLabel: updated ? updated.toLocaleDateString("zh-CN") : null,
    timestamp: published.getTime()
  };
});

const visibleArchiveItems = archiveItems;
const isArchiveDense = visibleArchiveItems.length > 12;
const formatTagCount = (count: number) => String(count).padStart(2, "0");
const getTagTone = (normalized: number) => {
  if (normalized >= 0.68) {
    return "warm";
  }
  if (normalized >= 0.3) {
    return "cool";
  }
  return "neutral";
};
const buildTagCloudItems = (items: typeof archiveItems) => {
  const tags = [...new Set(items.flatMap((item) => item.tags))].sort((a, b) =>
    a.localeCompare(b, "zh-Hans-CN")
  );
  const tagCounts = new Map(tags.map((tag) => [tag, 0]));

  for (const item of items) {
    for (const tag of item.tags) {
      tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
    }
  }

  const countValues = [...tagCounts.values()];
  const maxCount = countValues.length > 0 ? Math.max(...countValues) : 1;
  const minCount = countValues.length > 0 ? Math.min(...countValues) : 1;

  return tags.map((tag) => {
    const count = tagCounts.get(tag) ?? 0;
    const normalized = maxCount === minCount ? 0.55 : (count - minCount) / (maxCount - minCount);

    return {
      tag,
      count,
      countLabel: formatTagCount(count),
      tone: getTagTone(normalized)
    };
  });
};

const archiveYears = [...new Set(visibleArchiveItems.map((item) => item.year))].sort(
  (a, b) => Number(b) - Number(a)
);
const initialTagCloud = buildTagCloudItems(visibleArchiveItems);
const allTags = initialTagCloud.map((item) => item.tag);
const allCategories = [...new Set(visibleArchiveItems.map((item) => item.category))].map((category) => ({
  value: category,
  label: getPostCategoryLabel(category)
}));
const totalTags = allTags.length;

const minDate = visibleArchiveItems.length
  ? visibleArchiveItems.reduce(
      (min, item) => (item.dateKey < min ? item.dateKey : min),
      visibleArchiveItems[0].dateKey
    )
  : undefined;
const maxDate = visibleArchiveItems.length
  ? visibleArchiveItems.reduce(
      (max, item) => (item.dateKey > max ? item.dateKey : max),
      visibleArchiveItems[0].dateKey
    )
  : undefined;

const fallbackGroups = archiveYears.map((year) => ({
  key: year,
  label: `${year} 年`,
  items: visibleArchiveItems
    .filter((item) => item.year === year)
    .sort((a, b) => b.timestamp - a.timestamp)
}));
---

<BaseLayout title="归档">
  <section class="stack archive-page" data-reveal>
    <div class="archive-head">
      <div>
        <p class="section-kicker">Archive Lab</p>
        <h1 class="page-title">归档</h1>
      </div>
        <p class="muted" data-archive-overview>
          当前共有 {visibleArchiveItems.length} 篇文章，支持按年份、分类、标签与关键词快速定位；更细的条件收在高级筛选里。
        </p>
    </div>

    {visibleArchiveItems.length > 0 ? (
      <>
        <section class="surface filter-panel" data-archive-filter>
          <div class="filter-panel-head">
            <div>
              <p class="section-kicker">Archive Console</p>
              <h2 class="filter-panel-title">筛选工作台</h2>
            </div>
            <p class="muted filter-panel-copy">
              把时间、分类、标签和关键词组合起来，像整理档案一样快速定位内容。
            </p>
          </div>

          <div class="filter-layout">
            <section class="filter-block filter-block-primary">
              <div class="filter-block-head">
                <div>
                  <p class="filter-block-kicker">常用筛选</p>
                  <p class="filter-block-note">先用年份、分类、标签和关键词缩小范围，再决定是否打开高级筛选。</p>
                </div>
              </div>

              <div class="filter-grid filter-grid-basic">
                <label class="field">
                  <span>年份</span>
                  <select data-archive-year>
                    <option value="all">全部年份</option>
                    {archiveYears.map((year) => (
                      <option value={year}>{year} 年</option>
                    ))}
                  </select>
                </label>

                <label class="field">
                  <span>分类</span>
                  <select data-archive-category>
                    <option value="all">全部分类</option>
                    {allCategories.map((item) => (
                      <option value={item.value}>{item.label}</option>
                    ))}
                  </select>
                </label>

                <label class="field field-wide">
                  <span>关键词</span>
                  <input
                    type="search"
                    placeholder="搜索标题、摘要或标签"
                    inputmode="search"
                    autocomplete="off"
                    data-archive-query
                  />
                </label>
              </div>

              <div class="tag-advanced filter-block tag-block-inline">
                <div class="tag-advanced-head filter-block-head">
                  <div>
                    <p class="filter-block-kicker">标签组合</p>
                    <p class="filter-block-note">默认使用“匹配任一标签”；需要 AND / OR 切换时到高级筛选里调整。</p>
                  </div>
                  <button class="tag-clear-btn" type="button" data-archive-clear-tags>清空标签</button>
                </div>
                <div class="tag-chip-list" data-archive-tag-chips>
                  {initialTagCloud.map((item) => (
                    <button
                      type="button"
                      class={`tag-chip tag-chip-${item.tone}`}
                      data-archive-tag-button={item.tag}
                      aria-pressed="false"
                      aria-label={`标签 ${item.tag}，${item.count} 篇文章`}
                    >
                      <span class="tag-chip-name">{item.tag}</span>
                      <span class="tag-chip-count">{item.countLabel}</span>
                    </button>
                  ))}
                </div>
              </div>
            </section>

            <details class="filter-advanced" open={isArchiveDense}>
              <summary>高级筛选</summary>
              <div class="filter-advanced-grid">
                <label class="field">
                  <span>分组方式</span>
                  <select data-archive-granularity>
                    <option value="year">按年</option>
                    <option value="month">按月</option>
                    <option value="day">按天</option>
                  </select>
                </label>

                <label class="field">
                  <span>月份</span>
                  <select data-archive-month>
                    <option value="all">全部月份</option>
                  </select>
                </label>

                <label class="field">
                  <span>日期</span>
                  <select data-archive-day>
                    <option value="all">全部日期</option>
                  </select>
                </label>

                <label class="field">
                  <span>排序</span>
                  <select data-archive-sort>
                    <option value="desc">最新优先</option>
                    <option value="asc">最早优先</option>
                  </select>
                </label>

                <label class="field">
                  <span>标签模式</span>
                  <select data-archive-tag-mode>
                    <option value="or">匹配任一标签 (OR)</option>
                    <option value="and">必须包含全部标签 (AND)</option>
                  </select>
                </label>

                <label class="field field-wide">
                  <span>起始日期</span>
                  <input type="date" min={minDate} max={maxDate} data-archive-start-date />
                </label>

                <label class="field field-wide">
                  <span>结束日期</span>
                  <input type="date" min={minDate} max={maxDate} data-archive-end-date />
                </label>

                <label class="check-field check-field-advanced">
                  <input type="checkbox" data-archive-updated />
                  <span>仅看有更新记录</span>
                </label>
              </div>
            </details>
          </div>

          <div class="filter-actions">
            <div class="filter-status">
              <p class="muted filter-hint">默认只露出常用筛选；需要更细的时间和分组条件时再展开高级选项。</p>
            </div>

            <div class="filter-summary-card">
              <p class="filter-summary-label">结果概览</p>
              <p class="muted result-summary" data-archive-summary>
                显示 {visibleArchiveItems.length} / {visibleArchiveItems.length} 篇，按年分组。
              </p>
            </div>

            <button class="reset-btn" type="button" data-archive-reset>
              重置全部筛选
            </button>
          </div>
        </section>

        <div class="stack archive-results" data-archive-output>
          {fallbackGroups.map((group) => (
            <section class="surface archive-group">
              <h2 class="archive-heading">
                <span class="archive-dot"></span>
                <span class="archive-heading-text">{group.label}</span>
                <span class="archive-heading-count">{group.items.length} 篇</span>
              </h2>
              <ul class="archive-list">
                {group.items.map((item) => (
                  <li class="archive-item">
                    <div class="archive-item-main">
                      <a href={item.href}>{item.title}</a>
                      {item.description && <p class="archive-desc muted">{item.description}</p>}
                      <div class="archive-tags archive-info-row">
                        {item.hidden && <span class="archive-info-chip archive-info-chip-hidden">彩蛋内容</span>}
                        <span class="archive-info-chip">{item.categoryLabel}</span>
                        {item.series && <span class="archive-info-chip">系列 · {item.series}</span>}
                        {item.project && item.projectLabel && (
                          <a class="archive-info-chip" href={withBasePath(`/projects/${item.project}/`)}>
                            项目 · {item.projectLabel}
                          </a>
                        )}
                      </div>
                      {item.tags.length > 0 && (
                        <div class="archive-tags">
                          {item.tags.map((tag) => (
                            <a class="archive-tag" href={withBasePath(`/tags/${tagToUrlSegment(tag)}/`)}>
                              #{tag}
                            </a>
                          ))}
                        </div>
                      )}
                    </div>
                    <div class="archive-meta">
                      <time datetime={item.dateISO}>{item.dateLabel}</time>
                      {item.updatedDateLabel && <span class="updated-note">更新于 {item.updatedDateLabel}</span>}
                    </div>
                  </li>
                ))}
              </ul>
            </section>
          ))}
        </div>

        <script
          type="application/json"
          id="archive-data"
          set:html={JSON.stringify({ items: visibleArchiveItems, allTags, allCategories })}
        ></script>
        <script is:inline define:vars={{ tagBaseHref, projectBaseHref }}>
          (() => {
            const dataNode = document.getElementById("archive-data");
            const output = document.querySelector("[data-archive-output]");
            const overview = document.querySelector("[data-archive-overview]");
            const tagChipList = document.querySelector("[data-archive-tag-chips]");

            if (
              !(dataNode instanceof HTMLScriptElement) ||
              !(output instanceof HTMLElement) ||
              !(overview instanceof HTMLElement) ||
              !(tagChipList instanceof HTMLElement)
            ) {
              return;
            }

            let payload = null;
            try {
              payload = JSON.parse(dataNode.textContent || "{}");
            } catch {
              return;
            }

            const allItems = Array.isArray(payload?.items) ? payload.items : [];
            if (!Array.isArray(allItems) || allItems.length === 0) {
              return;
            }

            const getVisibleItems = () => allItems;

            const granularitySelect = document.querySelector("[data-archive-granularity]");
            const yearSelect = document.querySelector("[data-archive-year]");
            const monthSelect = document.querySelector("[data-archive-month]");
            const daySelect = document.querySelector("[data-archive-day]");
            const sortSelect = document.querySelector("[data-archive-sort]");
            const categorySelect = document.querySelector("[data-archive-category]");
            const tagModeSelect = document.querySelector("[data-archive-tag-mode]");
            const queryInput = document.querySelector("[data-archive-query]");
            const startDateInput = document.querySelector("[data-archive-start-date]");
            const endDateInput = document.querySelector("[data-archive-end-date]");
            const updatedCheckbox = document.querySelector("[data-archive-updated]");
            const clearTagsButton = document.querySelector("[data-archive-clear-tags]");
            const resetButton = document.querySelector("[data-archive-reset]");
            const summary = document.querySelector("[data-archive-summary]");

            if (
              !(granularitySelect instanceof HTMLSelectElement) ||
              !(yearSelect instanceof HTMLSelectElement) ||
              !(monthSelect instanceof HTMLSelectElement) ||
              !(daySelect instanceof HTMLSelectElement) ||
              !(sortSelect instanceof HTMLSelectElement) ||
              !(categorySelect instanceof HTMLSelectElement) ||
              !(tagModeSelect instanceof HTMLSelectElement) ||
              !(queryInput instanceof HTMLInputElement) ||
              !(startDateInput instanceof HTMLInputElement) ||
              !(endDateInput instanceof HTMLInputElement) ||
              !(updatedCheckbox instanceof HTMLInputElement) ||
              !(clearTagsButton instanceof HTMLButtonElement) ||
              !(resetButton instanceof HTMLButtonElement) ||
              !(summary instanceof HTMLElement)
            ) {
              return;
            }

            const defaultState = {
              granularity: "year",
              year: "all",
              month: "all",
              day: "all",
              sort: "desc",
              category: "all",
              query: "",
              updatedOnly: false,
              startDate: "",
              endDate: "",
              tagMode: "or"
            };

            const state = {
              ...defaultState,
              selectedTags: new Set()
            };

            const getCategoryOptions = (items) =>
              [...new Map(
                items
                  .filter((item) => item?.category && item?.categoryLabel)
                  .map((item) => [item.category, { value: item.category, label: item.categoryLabel }])
              ).values()].sort((left, right) => left.label.localeCompare(right.label, "zh-Hans-CN"));

            const getTagOptions = (items) =>
              [...new Set(items.flatMap((item) => (Array.isArray(item.tags) ? item.tags : [])))].sort((left, right) =>
                left.localeCompare(right, "zh-Hans-CN")
              );

            const tagCloudOffsets = ["0rem", "-0.04rem", "0.03rem", "-0.02rem"];
            const getTagTone = (normalized) => {
              if (normalized >= 0.68) {
                return "warm";
              }
              if (normalized >= 0.3) {
                return "cool";
              }
              return "neutral";
            };

            const getDateBounds = (items) => {
              if (items.length === 0) {
                return { min: "", max: "" };
              }

              const sortedKeys = items.map((item) => item.dateKey).sort();
              return { min: sortedKeys[0], max: sortedKeys[sortedKeys.length - 1] };
            };

            const allCategoryOptions = getCategoryOptions(allItems);

            const applyQueryPreset = () => {
              const params = new URLSearchParams(window.location.search);
              const category = normalizeKeyword(params.get("category") || "");
              if (category && allCategoryOptions.some((item) => item?.value === category)) {
                state.category = category;
              }

              const query = params.get("q");
              if (query) {
                state.query = query;
              }
            };

            const granularityLabelMap = {
              year: "年",
              month: "月",
              day: "日"
            };

            const compareDesc = (left, right) => (left === right ? 0 : left > right ? -1 : 1);
            const unique = (values) => [...new Set(values)];
            const normalizeKeyword = (value) => value.trim().toLowerCase();
            const formatTagCount = (count) => String(count).padStart(2, "0");

            const setSelectOptions = (select, stateKey, options, allLabel) => {
              while (select.firstChild) {
                select.removeChild(select.firstChild);
              }

              select.append(new Option(allLabel, "all"));
              for (const option of options) {
                select.append(new Option(option.label, option.value));
              }

              const current = state[stateKey];
              const exists = current !== "all" && options.some((option) => option.value === current);
              state[stateKey] = exists ? current : "all";
              select.value = state[stateKey];
            };

            const formatMonthLabel = (value) => {
              const [year, month] = value.split("-");
              return `${year} 年 ${month} 月`;
            };

            const formatDayLabel = (value) => {
              const [year, month, day] = value.split("-");
              return `${year} 年 ${month} 月 ${day} 日`;
            };

            const syncCategorySelect = (items) => {
              setSelectOptions(categorySelect, "category", getCategoryOptions(items), "全部分类");
            };

            const syncDateBounds = (items) => {
              const { min, max } = getDateBounds(items);

              if (min && max) {
                startDateInput.min = min;
                startDateInput.max = max;
                endDateInput.min = min;
                endDateInput.max = max;
              } else {
                startDateInput.removeAttribute("min");
                startDateInput.removeAttribute("max");
                endDateInput.removeAttribute("min");
                endDateInput.removeAttribute("max");
              }

              if (state.startDate && (min === "" || state.startDate < min || state.startDate > max)) {
                state.startDate = "";
              }

              if (state.endDate && (min === "" || state.endDate < min || state.endDate > max)) {
                state.endDate = "";
              }

              startDateInput.value = state.startDate;
              endDateInput.value = state.endDate;
            };

            const syncDateSelectCollections = (items) => {
              const years = unique(items.map((item) => item.year)).sort((a, b) => Number(b) - Number(a));
              setSelectOptions(
                yearSelect,
                "year",
                years.map((year) => ({ value: year, label: `${year} 年` })),
                "全部年份"
              );

              const yearItems = items.filter((item) => state.year === "all" || item.year === state.year);
              const months = unique(yearItems.map((item) => item.monthKey)).sort(compareDesc);
              setSelectOptions(
                monthSelect,
                "month",
                months.map((value) => ({ value, label: formatMonthLabel(value) })),
                "全部月份"
              );

              const monthItems = yearItems.filter(
                (item) => state.month === "all" || item.monthKey === state.month
              );
              const days = unique(monthItems.map((item) => item.dayKey)).sort(compareDesc);
              setSelectOptions(
                daySelect,
                "day",
                days.map((value) => ({ value, label: formatDayLabel(value) })),
                "全部日期"
              );
            };

            const syncTagButtons = (items) => {
              const tags = getTagOptions(items);
              const availableTagSet = new Set(tags);
              const tagCounts = new Map(tags.map((tag) => [tag, 0]));

              for (const item of items) {
                for (const tag of item.tags ?? []) {
                  if (tagCounts.has(tag)) {
                    tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
                  }
                }
              }

              const countValues = [...tagCounts.values()];
              const maxCount = countValues.length > 0 ? Math.max(...countValues) : 1;
              const minCount = countValues.length > 0 ? Math.min(...countValues) : 1;

              for (const tag of [...state.selectedTags]) {
                if (!availableTagSet.has(tag)) {
                  state.selectedTags.delete(tag);
                }
              }

              tagChipList.replaceChildren();

              tags.forEach((tag) => {
                const count = tagCounts.get(tag) ?? 0;
                const normalized = maxCount === minCount ? 0.55 : (count - minCount) / (maxCount - minCount);
                const button = document.createElement("button");
                button.type = "button";
                button.className = `tag-chip tag-chip-${getTagTone(normalized)}`;
                button.dataset.archiveTagButton = tag;
                button.setAttribute("aria-label", `标签 ${tag}，${count} 篇文章`);
                const isActive = state.selectedTags.has(tag);
                button.setAttribute("aria-pressed", String(isActive));
                button.classList.toggle("is-active", isActive);

                const name = document.createElement("span");
                name.className = "tag-chip-name";
                name.textContent = tag;

                const countNode = document.createElement("span");
                countNode.className = "tag-chip-count";
                countNode.textContent = formatTagCount(count);

                button.append(name, countNode);
                tagChipList.append(button);
              });
            };

            const matchDateFilter = (item) => {
              if (state.year !== "all" && item.year !== state.year) {
                return false;
              }
              if (state.month !== "all" && item.monthKey !== state.month) {
                return false;
              }
              if (state.day !== "all" && item.dayKey !== state.day) {
                return false;
              }
              if (state.startDate && item.dateKey < state.startDate) {
                return false;
              }
              if (state.endDate && item.dateKey > state.endDate) {
                return false;
              }
              return true;
            };

            const matchCategoryFilter = (item) =>
              state.category === "all" ? true : item.category === state.category;

            const matchTagFilter = (item) => {
              if (state.selectedTags.size === 0) {
                return true;
              }
              if (state.tagMode === "and") {
                for (const tag of state.selectedTags) {
                  if (!item.tags.includes(tag)) {
                    return false;
                  }
                }
                return true;
              }
              for (const tag of state.selectedTags) {
                if (item.tags.includes(tag)) {
                  return true;
                }
              }
              return false;
            };

            const matchKeyword = (item, keyword) => {
              if (!keyword) {
                return true;
              }
              if (item.title.toLowerCase().includes(keyword)) {
                return true;
              }
              if ((item.description || "").toLowerCase().includes(keyword)) {
                return true;
              }
              if ((item.categoryLabel || "").toLowerCase().includes(keyword)) {
                return true;
              }
              if ((item.series || "").toLowerCase().includes(keyword)) {
                return true;
              }
              if ((item.projectLabel || "").toLowerCase().includes(keyword)) {
                return true;
              }
              return item.tags.some((tag) => tag.includes(keyword));
            };

            const getFilteredItems = (items) =>
              items
                .filter(matchDateFilter)
                .filter(matchCategoryFilter)
                .filter((item) => (state.updatedOnly ? Boolean(item.updatedDateISO) : true))
                .filter(matchTagFilter)
                .filter((item) => matchKeyword(item, normalizeKeyword(state.query)))
                .sort((a, b) => (state.sort === "desc" ? b.timestamp - a.timestamp : a.timestamp - b.timestamp));

            const getGroupKey = (item) => {
              if (state.granularity === "month") {
                return item.monthKey;
              }
              if (state.granularity === "day") {
                return item.dayKey;
              }
              return item.year;
            };

            const getGroupLabel = (key) => {
              if (state.granularity === "month") {
                return formatMonthLabel(key);
              }
              if (state.granularity === "day") {
                return formatDayLabel(key);
              }
              return `${key} 年`;
            };

            const groupItems = (items) => {
              const map = new Map();

              for (const item of items) {
                const key = getGroupKey(item);
                const group = map.get(key) ?? [];
                group.push(item);
                map.set(key, group);
              }

              const direction = state.sort === "desc" ? -1 : 1;
              return [...map.entries()]
                .map(([key, groupedItems]) => ({ key, label: getGroupLabel(key), items: groupedItems }))
                .sort((left, right) => (left.key === right.key ? 0 : (left.key > right.key ? 1 : -1) * direction));
            };

            const createGroupNode = (group) => {
              const groupNode = document.createElement("section");
              groupNode.className = "surface archive-group";

              const heading = document.createElement("h2");
              heading.className = "archive-heading";
              const dot = document.createElement("span");
              dot.className = "archive-dot";
              const headingText = document.createElement("span");
              headingText.className = "archive-heading-text";
              headingText.textContent = group.label;
              const headingCount = document.createElement("span");
              headingCount.className = "archive-heading-count";
              headingCount.textContent = `${group.items.length} 篇`;
              heading.append(dot, headingText, headingCount);

              const list = document.createElement("ul");
              list.className = "archive-list";

              for (const item of group.items) {
                const listItem = document.createElement("li");
                listItem.className = "archive-item";

                const main = document.createElement("div");
                main.className = "archive-item-main";
                const title = document.createElement("a");
                title.href = item.href;
                title.textContent = item.title;
                main.append(title);

                if (item.description) {
                  const description = document.createElement("p");
                  description.className = "archive-desc muted";
                  description.textContent = item.description;
                  main.append(description);
                }

                const infoWrap = document.createElement("div");
                infoWrap.className = "archive-tags archive-info-row";

                if (item.hidden) {
                  const hiddenNode = document.createElement("span");
                  hiddenNode.className = "archive-info-chip archive-info-chip-hidden";
                  hiddenNode.textContent = "彩蛋内容";
                  infoWrap.append(hiddenNode);
                }

                const categoryNode = document.createElement("span");
                categoryNode.className = "archive-info-chip";
                categoryNode.textContent = item.categoryLabel;
                infoWrap.append(categoryNode);

                if (item.series) {
                  const seriesNode = document.createElement("span");
                  seriesNode.className = "archive-info-chip";
                  seriesNode.textContent = `系列 · ${item.series}`;
                  infoWrap.append(seriesNode);
                }

                if (item.project && item.projectLabel) {
                  const projectNode = document.createElement("a");
                  projectNode.className = "archive-info-chip";
                  projectNode.href = `${projectBaseHref}${encodeURIComponent(item.project)}/`;
                  projectNode.textContent = `项目 · ${item.projectLabel}`;
                  infoWrap.append(projectNode);
                }

                main.append(infoWrap);

                if (item.tags.length > 0) {
                  const tagWrap = document.createElement("div");
                  tagWrap.className = "archive-tags";
                  for (const tag of item.tags) {
                    const tagNode = document.createElement("a");
                    tagNode.className = "archive-tag";
                    tagNode.href = `${tagBaseHref}${encodeURIComponent(String(tag).trim().toLowerCase())}/`;
                    tagNode.textContent = `#${tag}`;
                    tagWrap.append(tagNode);
                  }
                  main.append(tagWrap);
                }

                const meta = document.createElement("div");
                meta.className = "archive-meta";
                const pubDate = document.createElement("time");
                pubDate.dateTime = item.dateISO;
                pubDate.textContent = item.dateLabel;
                meta.append(pubDate);

                if (item.updatedDateISO && item.updatedDateLabel) {
                  const updated = document.createElement("span");
                  updated.className = "updated-note";
                  updated.textContent = `更新于 ${item.updatedDateLabel}`;
                  meta.append(updated);
                }

                listItem.append(main, meta);
                list.append(listItem);
              }

              groupNode.append(heading, list);
              return groupNode;
            };

            const updateSummary = (filteredCount, groupCount, totalCount) => {
              const tagArray = [...state.selectedTags];
              const categoryInfo =
                state.category !== "all"
                  ? `；分类: ${categorySelect.options[categorySelect.selectedIndex]?.text || state.category}`
                  : "";
              const tagInfo =
                tagArray.length > 0
                  ? `；标签(${state.tagMode.toUpperCase()}): ${tagArray.map((tag) => `#${tag}`).join(", ")}`
                  : "";
              const rangeInfo =
                state.startDate || state.endDate
                  ? `；范围: ${state.startDate || "..."} ~ ${state.endDate || "..."}`
                  : "";
              summary.textContent = `显示 ${filteredCount} / ${totalCount} 篇，按${
                granularityLabelMap[state.granularity]
              }分组共 ${groupCount} 组${categoryInfo}${tagInfo}${rangeInfo}。`;
            };

            const updateOverview = (items) => {
              const categoryCount = getCategoryOptions(items).length;
              const tagCount = getTagOptions(items).length;
              overview.textContent = `支持按年、月、日、日期区间、分类、标签与关键词的组合筛选。当前共有 ${items.length} 篇文章，${categoryCount} 个分类，${tagCount} 个标签。`;
            };

            const syncQueryPreset = () => {
              const params = new URLSearchParams(window.location.search);
              if (state.category !== "all") {
                params.set("category", state.category);
              } else {
                params.delete("category");
              }

              const normalizedQuery = state.query.trim();
              if (normalizedQuery) {
                params.set("q", normalizedQuery);
              } else {
                params.delete("q");
              }

              const nextSearch = params.toString();
              const nextUrl = nextSearch ? `${window.location.pathname}?${nextSearch}` : window.location.pathname;
              window.history.replaceState({}, "", nextUrl);
            };

            const render = () => {
              const visibleItems = getVisibleItems();
              syncCategorySelect(visibleItems);
              syncDateSelectCollections(visibleItems);
              syncDateBounds(visibleItems);
              syncTagButtons(visibleItems);
              updateOverview(visibleItems);

              const filtered = getFilteredItems(visibleItems);
              const groups = groupItems(filtered);
              output.replaceChildren();

              if (groups.length === 0) {
                const empty = document.createElement("p");
                empty.className = "surface empty muted";
                empty.textContent = "没有匹配结果，试试放宽筛选条件。";
                output.append(empty);
              } else {
                for (const group of groups) {
                  output.append(createGroupNode(group));
                }
              }

              updateSummary(filtered.length, groups.length, visibleItems.length);
              syncQueryPreset();
            };

            const normalizeDateRange = () => {
              if (state.startDate && state.endDate && state.startDate > state.endDate) {
                state.endDate = state.startDate;
                endDateInput.value = state.endDate;
              }
            };

            const bindControls = () => {
              granularitySelect.addEventListener("change", () => {
                state.granularity = granularitySelect.value;
                render();
              });

              yearSelect.addEventListener("change", () => {
                state.year = yearSelect.value;
                state.month = "all";
                state.day = "all";
                render();
              });

              monthSelect.addEventListener("change", () => {
                state.month = monthSelect.value;
                state.day = "all";
                render();
              });

              daySelect.addEventListener("change", () => {
                state.day = daySelect.value;
                render();
              });

              sortSelect.addEventListener("change", () => {
                state.sort = sortSelect.value;
                render();
              });

              categorySelect.addEventListener("change", () => {
                state.category = categorySelect.value;
                render();
              });

              tagModeSelect.addEventListener("change", () => {
                state.tagMode = tagModeSelect.value;
                render();
              });

              queryInput.addEventListener("input", () => {
                state.query = queryInput.value;
                render();
              });

              startDateInput.addEventListener("change", () => {
                state.startDate = startDateInput.value;
                normalizeDateRange();
                render();
              });

              endDateInput.addEventListener("change", () => {
                state.endDate = endDateInput.value;
                if (state.startDate && state.endDate && state.startDate > state.endDate) {
                  state.startDate = state.endDate;
                  startDateInput.value = state.startDate;
                }
                render();
              });

              updatedCheckbox.addEventListener("change", () => {
                state.updatedOnly = updatedCheckbox.checked;
                render();
              });

              tagChipList.addEventListener("click", (event) => {
                const target = event.target;
                if (!(target instanceof Element)) {
                  return;
                }

                const button = target.closest("[data-archive-tag-button]");
                if (!(button instanceof HTMLButtonElement)) {
                  return;
                }

                const tag = button.dataset.archiveTagButton;
                if (!tag) {
                  return;
                }

                if (state.selectedTags.has(tag)) {
                  state.selectedTags.delete(tag);
                } else {
                  state.selectedTags.add(tag);
                }
                render();
              });

              clearTagsButton.addEventListener("click", () => {
                state.selectedTags.clear();
                render();
              });

              resetButton.addEventListener("click", () => {
                state.granularity = defaultState.granularity;
                state.year = defaultState.year;
                state.month = defaultState.month;
                state.day = defaultState.day;
                state.sort = defaultState.sort;
                state.category = defaultState.category;
                state.query = defaultState.query;
                state.updatedOnly = defaultState.updatedOnly;
                state.startDate = defaultState.startDate;
                state.endDate = defaultState.endDate;
                state.tagMode = defaultState.tagMode;
                state.selectedTags.clear();

                granularitySelect.value = state.granularity;
                sortSelect.value = state.sort;
                categorySelect.value = state.category;
                tagModeSelect.value = state.tagMode;
                queryInput.value = state.query;
                updatedCheckbox.checked = state.updatedOnly;
                startDateInput.value = state.startDate;
                endDateInput.value = state.endDate;
                render();
              });
            };

            applyQueryPreset();

            granularitySelect.value = state.granularity;
            sortSelect.value = state.sort;
            categorySelect.value = state.category;
            tagModeSelect.value = state.tagMode;
            queryInput.value = state.query;
            updatedCheckbox.checked = state.updatedOnly;
            startDateInput.value = state.startDate;
            endDateInput.value = state.endDate;

            bindControls();
            render();
          })();
        </script>
      </>
    ) : (
      <p class="surface empty muted">暂无文章。</p>
    )}
  </section>
</BaseLayout>

