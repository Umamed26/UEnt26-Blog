---
import { render } from "astro:content";
import CodeBlockWrapper from "@/components/CodeBlockWrapper.astro";
import BaseLayout from "@/layouts/BaseLayout.astro";
import { withBasePath } from "@/utils/paths";
import { getCurrentNowEntry, getCurrentNowSnapshot } from "@/utils/now";

const nowEntry = await getCurrentNowEntry();
const nowSnapshot = await getCurrentNowSnapshot();
const updatedAt = nowSnapshot.updatedDate.toLocaleDateString("zh-CN");
const renderedNow = nowEntry ? await render(nowEntry) : undefined;
const Content = renderedNow?.Content;
---

<BaseLayout title="Now">
  <section class="stack now-page" data-reveal>
    <header class="surface now-hero">
      <p class="section-kicker">Now</p>
      <h1 class="page-title">{nowSnapshot.title}</h1>
      <p class="muted">
        {nowSnapshot.description} 最后更新：{updatedAt}。
      </p>
    </header>

    <section class="focus-grid" data-reveal style="--reveal-delay: 70ms;">
      {nowSnapshot.focusItems.map((item) => (
        <article class="surface focus-card">
          <h2>{item.title}</h2>
          <p class="muted">{item.detail}</p>
        </article>
      ))}
    </section>

    <section class="content-grid" data-reveal style="--reveal-delay: 110ms;">
      <section class="stack section-wrap">
        <h2 class="section-title">最近在更新</h2>
        <ul class="now-list">
          {nowSnapshot.currentItems.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </section>

      <section class="stack section-wrap">
        <h2 class="section-title">接下来会补</h2>
        <ul class="now-list">
          {nowSnapshot.nextItems.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </section>
    </section>

    {Content && (
      <section class="surface note-card" data-reveal style="--reveal-delay: 140ms;">
        <p class="section-kicker">Why This Page</p>
        <h2 class="section-title">为什么值得看这页</h2>
        <CodeBlockWrapper>
          <Content />
        </CodeBlockWrapper>
      </section>
    )}

    <section class="surface quick-links" data-reveal style="--reveal-delay: 170ms;">
      <p class="section-kicker">Start Here</p>
      <h2 class="section-title">接着逛</h2>
      <div class="link-row">
        {nowSnapshot.quickLinks.map((item) => (
          <a href={withBasePath(item.href)}>{item.label}</a>
        ))}
      </div>
    </section>
  </section>
</BaseLayout>

<style>
  .now-page {
    gap: 1rem;
  }

  .now-hero,
  .focus-card,
  .section-wrap,
  .quick-links,
  .note-card {
    padding: 1.2rem;
    border-radius: var(--radius-lg);
  }

  .now-hero {
    display: grid;
    gap: 0.7rem;
  }

  .now-hero p,
  .focus-card p {
    margin: 0;
  }

  .focus-grid,
  .content-grid {
    display: grid;
    gap: 0.8rem;
  }

  .focus-card {
    display: grid;
    gap: 0.46rem;
  }

  .focus-card h2 {
    margin: 0;
    font-family: "Space Grotesk", "IBM Plex Sans", sans-serif;
    font-size: 1.08rem;
    line-height: 1.3;
  }

  .section-wrap,
  .note-card {
    border: 1px solid rgba(218, 205, 184, 0.9);
    background: rgba(255, 255, 255, 0.42);
  }

  .now-list {
    margin: 0;
    padding-left: 1.15rem;
    display: grid;
    gap: 0.52rem;
  }

  .now-list li {
    color: var(--text);
    line-height: 1.58;
  }

  .quick-links {
    display: grid;
    gap: 0.7rem;
  }

  .link-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .link-row a {
    border-radius: 999px;
    border: 1px solid rgba(31, 120, 117, 0.3);
    background: rgba(31, 120, 117, 0.08);
    color: var(--accent-cyan);
    padding: 0.28rem 0.72rem;
    font-size: 0.82rem;
    font-weight: 600;
  }

  .link-row a:hover {
    border-color: rgba(31, 120, 117, 0.48);
    background: rgba(31, 120, 117, 0.14);
    color: var(--accent-cyan);
  }

  @media (min-width: 860px) {
    .focus-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .content-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  :global(html[data-theme="dark"]) .focus-card,
  :global(html[data-theme="dark"]) .section-wrap,
  :global(html[data-theme="dark"]) .quick-links,
  :global(html[data-theme="dark"]) .note-card {
    border-color: rgba(45, 59, 75, 0.95);
  }

  :global(html[data-theme="dark"]) .section-wrap,
  :global(html[data-theme="dark"]) .note-card {
    background: rgba(16, 24, 34, 0.46);
  }

  :global(html[data-theme="dark"]) .link-row a {
    border-color: rgba(86, 198, 194, 0.34);
    background: rgba(86, 198, 194, 0.12);
    color: var(--accent-cyan-soft);
  }
</style>
